# ── Email delivery for website forms (Contact + Become a Partner) ──
# Copy this file to ".env.local", fill in SMTP_PASS (and confirm SMTP_HOST),
# then restart the server. Submissions are emailed to CONTACT_TO.
#
# ── Self-hosted VPS + Hestia Control Panel (Exim/Dovecot/Roundcube) ──
# In Hestia: MAIL > synchronixintegrated.com > the "info" account >
#   the "Open Webmail / Configure" area shows the SMTP host & ports.
# Typically:
#   SMTP_HOST = mail.synchronixintegrated.com   (or your server's FQDN/hostname)
#   SMTP_PORT = 465 (SSL)  — or 587 (STARTTLS)
#   SMTP_USER = full email address
#   SMTP_PASS = that mailbox's password (the one you set in Hestia)

SMTP_HOST=mail.synchronixintegrated.com
SMTP_PORT=465
SMTP_USER=info@synchronixintegrated.com
SMTP_PASS=
CONTACT_TO=info@synchronixintegrated.com
CONTACT_FROM=info@synchronixintegrated.com

# Advanced / troubleshooting (usually leave unset):
# Force secure mode regardless of port (true for 465, false for 587):
# SMTP_SECURE=true
# If you get a TLS error like "self-signed certificate" or "hostname/altnames
# mismatch" (common on fresh Hestia mail certs), set this to false to accept it:
# SMTP_TLS_REJECT_UNAUTHORIZED=false
